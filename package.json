{
  "name": "@cyanheads/faa-aircraft-registry-mcp-server",
  "version": "0.1.0",
  "mcpName": "io.github.cyanheads/faa-aircraft-registry-mcp-server",
  "description": "Offline, keyless MCP server for the US civil aircraft registry (FAA Releasable Aircraft Database) — decode an N-number to aircraft, engine, status, and owner; search by owner, type, or state; resolve active/deregistered/reserved status. Embedded SQLite + FTS5, fail-safe owner-PII redaction.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "faa-aircraft-registry-mcp-server": "dist/index.js"
  },
  "files": [
    "changelog/",
    "dist/",
    "scripts/_mirror-context.ts",
    "scripts/faa-mirror-init.ts",
    "scripts/faa-mirror-refresh.ts",
    "scripts/faa-mirror-verify.ts",
    "README.md",
    "LICENSE",
    "CLAUDE.md",
    "AGENTS.md",
    "Dockerfile",
    "server.json"
  ],
  "scripts": {
    "build": "bun run scripts/build.ts",
    "rebuild": "bun run scripts/clean.ts && bun run scripts/build.ts",
    "clean": "bun run scripts/clean.ts",
    "devcheck": "bun run scripts/devcheck.ts",
    "audit:refresh": "rm -f bun.lock && bun install && bun audit",
    "tree": "bun run scripts/tree.ts",
    "list-skills": "bun run scripts/list-skills.ts",
    "format": "biome check --write .",
    "format:unsafe": "biome check --write --unsafe .",
    "lint:mcp": "bun run scripts/lint-mcp.ts",
    "lint:packaging": "bun run scripts/lint-packaging.ts",
    "bundle": "bun run build && npx -y @anthropic-ai/mcpb pack . dist/faa-aircraft-registry-mcp-server.mcpb && bun run scripts/clean-mcpb.ts dist/faa-aircraft-registry-mcp-server.mcpb",
    "changelog:build": "bun run scripts/build-changelog.ts",
    "changelog:check": "bun run scripts/build-changelog.ts --check",
    "release:github": "bun run scripts/release-github.ts",
    "publish-mcp": "mcp-publisher login github -token \"$(security find-generic-password -a \"$USER\" -s mcp-publisher-github-pat -w)\" && mcp-publisher publish",
    "test": "vitest run",
    "mirror:init": "bun run scripts/faa-mirror-init.ts",
    "mirror:refresh": "bun run scripts/faa-mirror-refresh.ts",
    "mirror:verify": "bun run scripts/faa-mirror-verify.ts",
    "start": "node dist/index.js",
    "start:stdio": "MCP_TRANSPORT_TYPE=stdio node dist/index.js",
    "start:http": "MCP_TRANSPORT_TYPE=http node dist/index.js"
  },
  "keywords": [
    "mcp",
    "mcp-server",
    "model-context-protocol",
    "typescript",
    "bun",
    "stdio",
    "streamable-http",
    "ai-agent",
    "faa",
    "aircraft-registry",
    "n-number",
    "tail-number",
    "aviation",
    "mode-s",
    "icao24",
    "aircraft-registration",
    "sqlite",
    "fts5"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cyanheads/faa-aircraft-registry-mcp-server.git"
  },
  "homepage": "https://github.com/cyanheads/faa-aircraft-registry-mcp-server#readme",
  "bugs": {
    "url": "https://github.com/cyanheads/faa-aircraft-registry-mcp-server/issues"
  },
  "author": "cyanheads <casey@caseyjhand.com> (https://github.com/cyanheads/faa-aircraft-registry-mcp-server#readme)",
  "funding": [
    {
      "type": "github",
      "url": "https://github.com/sponsors/cyanheads"
    },
    {
      "type": "buy_me_a_coffee",
      "url": "https://www.buymeacoffee.com/cyanheads"
    }
  ],
  "license": "Apache-2.0",
  "engines": {
    "bun": ">=1.3.0",
    "node": ">=24.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@cyanheads/mcp-ts-core": "^0.10.6",
    "node-cron": "^4.2.1",
    "pino-pretty": "^13.1.3",
    "zod": "^4.4.3"
  },
  "peerDependencies": {
    "better-sqlite3": "^12.0.0"
  },
  "peerDependenciesMeta": {
    "better-sqlite3": {
      "optional": true
    }
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.0",
    "@types/node": "25.9.3",
    "better-sqlite3": "^12.0.0",
    "depcheck": "^1.4.7",
    "ignore": "^7.0.5",
    "tsc-alias": "^1.8.17",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  },
  "trustedDependencies": ["better-sqlite3"]
}
